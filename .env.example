# Gravtory Environment Configuration
# Copy this file to .env and fill in your values.

# Database backend connection string
# Supported: postgresql://, sqlite://, mysql://, mongodb://, redis://
GRAVTORY_BACKEND=sqlite:///gravtory.db

# PostgreSQL example:
# GRAVTORY_BACKEND=postgresql://user:password@localhost:5432/gravtory

# MySQL example:
# GRAVTORY_BACKEND=mysql://user:password@localhost:3306/gravtory

# MongoDB example:
# GRAVTORY_BACKEND=mongodb://localhost:27017/gravtory

# Redis example:
# GRAVTORY_BACKEND=redis://localhost:6379/0

# Encryption key for checkpoint data (AES-256-GCM)
# Leave empty to disable encryption
# GRAVTORY_ENCRYPTION_KEY=your-secret-key-here

# Dashboard authentication token
# Set to require Bearer token auth for dashboard API
# GRAVTORY_DASHBOARD_TOKEN=your-dashboard-token

# OpenTelemetry endpoint for distributed tracing
# GRAVTORY_OTEL_ENDPOINT=http://localhost:4317

# Prometheus metrics port
# GRAVTORY_METRICS_PORT=9090

# Docker-compose PostgreSQL credentials
# Required when using docker-compose.yml
POSTGRES_USER=gravtory
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=gravtory
